{
  "name": "geohazardwatch",
  "version": "1.2.12",
  "description": "Volcano & geology add-on for ngdpbase",
  "private": true,
  "scripts": {
    "import": "node addons/geohazardwatch/import/import-volcanoes.js",
    "import:eruptions": "node addons/geohazardwatch/import/import-volcanoes.js --eruptions",
    "import:activity": "node addons/geohazardwatch/import/import-volcanoes.js --activity",
    "import:all": "node addons/geohazardwatch/import/import-volcanoes.js --eruptions --activity",
    "import:earthquakes": "node addons/geohazardwatch/import/import-earthquakes.js",
    "import:earthquakes:month": "node addons/geohazardwatch/import/import-earthquakes.js --feed=4.5-month",
    "import:hans": "node addons/geohazardwatch/import/import-hans.js",
    "lint": "npm run lint:code && npm run lint:md",
    "lint:code": "eslint addons/**/*.js",
    "lint:code:fix": "eslint addons/**/*.js --fix",
    "lint:md": "npx markdownlint \"**/*.md\" --ignore node_modules --ignore private",
    "lint:md:fix": "npx markdownlint \"**/*.md\" --ignore node_modules --ignore private --fix",
    "lint:fix": "npm run lint:code:fix && npm run lint:md:fix",
    "format": "prettier --write \"addons/**/*.js\"",
    "format:check": "prettier --check \"addons/**/*.js\"",
    "prepare": "husky install",
    "version:bump": "tsx src/utils/version.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.1",
    "husky": "^8.0.3",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.20.2",
    "npm": ">=10.0.0"
  },
  "author": "jwilleke",
  "license": "MIT"
}
